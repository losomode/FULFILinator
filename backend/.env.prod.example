# Fulfilinator — Production Environment
# Copy to .env.prod and fill in real values before deploying.

SECRET_KEY=change-me-to-a-long-random-string-50-chars-minimum
DEBUG=False

DEPLOY_DOMAIN=www.yourapp.com
DEPLOY_SCHEME=https

ALLOWED_HOSTS=www.yourapp.com,yourapp.com

# SQLite path — written to the Docker named volume
SQLITE_PATH=/app/backend/data/db.sqlite3

# Set automatically by docker-compose.yml via environment:
# AUTHINATOR_API_URL=http://authinator:8001/api/auth/
# SERVICE_REGISTRY_URL=http://authinator:8001/api/services/register/

SERVICE_REGISTRATION_KEY=change-me-to-a-strong-random-key
